{
  "name": "claude-statusbar",
  "displayName": "Claude Status Bar",
  "description": "Shows Claude Code session status in the VS Code status bar and a multi-session dashboard",
  "version": "0.2.0",
  "publisher": "local",
  "engines": { "vscode": "^1.60.0" },
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeStatusbar.showDashboard",
        "title": "Claude: Show Session Dashboard"
      }
    ]
  }
}
